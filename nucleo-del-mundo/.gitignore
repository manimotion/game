# Caché del editor de Godot (se regenera solo)
.godot/

# Plantillas .aar de Android de Godot: artefactos pesados (>50/100 MB) que
# exceden el límite de GitHub. Se regeneran al instalar la plantilla de
# compilación de Android (Proyecto → Instalar plantilla de compilación).
android/build/libs/
*.aar

# Salida de exports (web/desktop): artefactos de build, no van a git.
# Para itch.io subes el zip de export/web/ por separado.
export/
